# Nginx Blue-Green Load Balancer Config
# Generated by Ansible on {{ ansible_date_time.iso8601 }}
# Active slot: {{ active_slot }} → port {{ active_port }}

# Blue slot — always runs on port 8080
server {
    listen 8080;
    server_name _;
    root /var/www/blue;
    index index.html;

    location / {
        try_files $uri $uri/ =404;
    }

    # Health check endpoint — Jenkins uses this to verify the slot is healthy
    location /health {
        return 200 '{"slot":"blue","status":"ok"}';
        add_header Content-Type application/json;
    }
}

# Green slot — always runs on port 8081
server {
    listen 8081;
    server_name _;
    root /var/www/green;
    index index.html;

    location / {
        try_files $uri $uri/ =404;
    }

    location /health {
        return 200 '{"slot":"green","status":"ok"}';
        add_header Content-Type application/json;
    }
}

# PUBLIC ENTRY POINT — port 80 routes to active slot
# THIS IS THE TRAFFIC SWITCH — changing active_port switches traffic
upstream active_app {
    server 127.0.0.1:{{ active_port }};  ← {{ active_port }} is 8080 or 8081
}

server {
    listen 80;
    server_name _;

    # Add custom header so you can see which slot is serving
    add_header X-Active-Slot "{{ active_slot }}" always;
    add_header X-App-Version "{{ app_version | default('unknown') }}" always;

    location / {
        proxy_pass http://active_app;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;

        # Timeouts — prevent long waits if app is slow
        proxy_connect_timeout 5s;
        proxy_read_timeout 30s;
    }

    # Status endpoint to check which slot is live
    location /slot-status {
        return 200 '{"active":"{{ active_slot }}","port":{{ active_port }}}';
        add_header Content-Type application/json;
    }
}
